# ─── Resend (contact form) ────────────────────────────────────────────────────
# 1. Sign up free at https://resend.com
# 2. Create an API key (Sending access)
# 3. Verify your domain (garaadsystems.com) in the Resend dashboard
#    → Settings → Domains → Add Domain
#    Without a verified domain, leave RESEND_FROM_EMAIL unset and Resend will
#    use onboarding@resend.dev (fine for testing, not for production).

RESEND_API_KEY=...replace_with_your_own_resend_api_key..

# Email the form submissions are sent FROM (must match your verified Resend domain)
RESEND_FROM_EMAIL="Garaad Systems <noreply@garaadsystems.com>"

# Email the form submissions are sent TO
CONTACT_TO_EMAIL=info@garaadsystems.com
